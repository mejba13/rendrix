# ============================================
# Docker Ignore File
# ============================================
# Excludes files/folders from Docker build context
# to speed up builds and reduce image size

# Dependencies (will be installed fresh in container)
node_modules
**/node_modules
.pnpm-store

# Build outputs (will be built in container)
dist
**/dist
.next
**/.next
.turbo
**/.turbo
out
**/out
build
**/build

# Development and IDE
.git
.gitignore
.vscode
.idea
*.swp
*.swo

# Environment files (secrets - should use Docker secrets or env vars)
.env
.env.*
!.env.example

# Documentation (not needed in container)
*.md
!README.md
docs

# Testing
coverage
**/.nyc_output
*.test.ts
*.spec.ts
__tests__
**/__tests__

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Docker files (not needed in build context)
docker-compose*.yml
!docker-compose.yml

# Nginx config (mounted separately in prod)
nginx

# CI/CD
.github
.gitlab-ci.yml
.circleci

# Misc
*.tgz
*.tar.gz
.husky
.prettierrc
.prettierignore
.eslintrc*
.eslintignore
LICENSE
CHANGELOG.md
