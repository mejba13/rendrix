# ============================================
# Rendrix Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ============================================
# Database (PostgreSQL)
# ============================================
# For local development (without Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rendrix?schema=public"

# For Docker Compose (set in docker-compose.yml, override here if needed)
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/rendrix?schema=public"

# Production database credentials (used by docker-compose.prod.yml)
DB_USER="postgres"
DB_PASSWORD="your-secure-db-password"

# ============================================
# Redis
# ============================================
# For local development (without Docker)
REDIS_URL="redis://localhost:6379"

# For Docker Compose (set in docker-compose.yml, override here if needed)
# REDIS_URL="redis://redis:6379"

# Production Redis password (used by docker-compose.prod.yml)
REDIS_PASSWORD="your-secure-redis-password"

# ============================================
# Authentication (JWT)
# ============================================
# IMPORTANT: Change these in production! Use: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ============================================
# Stripe (Payments)
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# OAuth Providers
# ============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# Email (SMTP)
# ============================================
# For local development, use Mailhog (runs on port 1025)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@rendrix.com"

# ============================================
# AWS S3 / MinIO (Media Storage)
# ============================================
# For local development with MinIO
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="rendrix-media"
AWS_ENDPOINT="http://localhost:9000"

# For production AWS S3
# AWS_ACCESS_KEY_ID="your-aws-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret"
# AWS_S3_BUCKET="your-production-bucket"
# AWS_ENDPOINT=""  # Leave empty for AWS S3

# ============================================
# Meilisearch (Product Search)
# ============================================
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_KEY="rendrix-dev-master-key"

# ============================================
# Application URLs
# ============================================
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Next.js public environment variables
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# Error Tracking (Sentry)
# ============================================
SENTRY_DSN=""
