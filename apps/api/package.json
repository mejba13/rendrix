{
  "name": "@rendrix/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --dts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@rendrix/database": "workspace:*",
    "@rendrix/types": "workspace:*",
    "@rendrix/utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "fastify": "^4.25.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/cookie": "^9.2.0",
    "@fastify/multipart": "^8.1.0",
    "ioredis": "^5.3.0",
    "nanoid": "^5.0.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "resend": "^2.1.0",
    "stripe": "^14.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@rendrix/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
